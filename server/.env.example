# MongoDB Atlas connection string (free M0 tier)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/trot_invoice?retryWrites=true&w=majority

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret

# Seeded admin credentials (used by `npm run seed`)
ADMIN_EMAIL=admin@trottk.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Trot TK Admin

# Secret to allow re-seeding/password-reset via POST /api/auth/seed after an admin exists.
# (First-run seeding needs no secret; this only gates resets.)
SEED_SECRET=change_this_seed_secret

# Frontend origin allowed by CORS (local dev default)
CLIENT_ORIGIN=http://localhost:5173

# Port for local dev
PORT=5000
